SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
NETWORK_INTERFACE=eth0
LOG_FILE=iot_defender_dhcp.log
SUPABASE_DEVICES_TABLE=devices
SUPABASE_METRICS_TABLE=device_metrics
DHCP_DUPLICATE_WINDOW_SEC=20
DISCONNECT_TIMEOUT_SEC=60
METRICS_SAMPLE_INTERVAL_SEC=10
PING_COUNT=3
PING_TIMEOUT_SEC=1
SHOW_PACKET_LOGS=true
